{
  "name": "structural-engineering-book",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "build:offline": "tsc -b && vite build --mode offline --outDir dist-offline",
    "bundle:offline": "npm run build:offline && powershell -ExecutionPolicy Bypass -File ./bundle-offline.ps1",
    "preview": "vite preview --host 127.0.0.1",
    "test:e2e": "npm run bundle:offline && playwright test",
    "test:e2e:headed": "npm run bundle:offline && playwright test --headed"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "katex": "^0.16.9",
    "lucide-react": "latest",
    "marked": "^12.0.2",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
